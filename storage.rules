rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      // Allow read access to all users (authenticated or not)
      // This is often needed for public profile photos and portfolios
      allow read: if true;
      
      // Allow write access only to authenticated users who are verified or are initial admins
      allow write: if request.auth != null && (
        request.auth.token.email_verified == true || 
        request.auth.token.email.lower() == 'marufadam7777@gmail.com' ||
        request.auth.token.email.lower() == 'beisiwaa00@gmail.com' ||
        request.auth.token.email.lower() == 'r9628606@gmail.com'
      );
    }
  }
}
