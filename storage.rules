rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      // Allow read access to all users (authenticated or not)
      // This is often needed for public profile photos and portfolios
      allow read: if true;
      
      // Allow write access only to authenticated users
      // In a more restricted app, you would check if they are "Staff"
      allow write: if request.auth != null;
    }
  }
}
