rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isInitialAdmin() {
      return isSignedIn() && 
             request.auth.token.email != null &&
             (request.auth.token.email.lower() == 'marufadam7777@gmail.com' || 
              request.auth.token.email.lower() == 'beisiwaa00@gmail.com' ||
              request.auth.token.email.lower() == 'r9628606@gmail.com');
    }

    function isAdmin() {
      return isSignedIn() && (
        isInitialAdmin() ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }

    function isStaff() {
      return isSignedIn() && (
        isInitialAdmin() ||
        exists(/databases/$(database)/documents/users/$(request.auth.uid))
      );
    }

    function isValidUser(data) {
      return data.keys().hasAll(['name', 'email', 'role', 'createdAt']) &&
             data.name is string && data.name.size() <= 100 &&
             data.email is string &&
             data.role in ['admin', 'staff'] &&
             (data.createdAt is timestamp || data.createdAt == request.time);
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if (isAdmin() || request.auth.uid == userId) && isValidUser(request.resource.data);
      allow update: if (isAdmin() || request.auth.uid == userId) && 
                    request.resource.data.diff(resource.data).affectedKeys().hasOnly(['name', 'role']);
      allow delete: if isAdmin();
    }

    match /students/{studentId} {
      allow read: if isSignedIn();
      allow create, update: if isStaff();
      allow delete: if isAdmin();
    }

    match /payments/{paymentId} {
      allow read: if isSignedIn();
      allow create, update: if isStaff();
      allow delete: if isAdmin();
    }

    match /attendance/{attendanceId} {
      allow read: if isSignedIn();
      allow create, update: if isStaff();
      allow delete: if isAdmin();
    }

    match /portfolio/{itemId} {
      allow read: if isSignedIn();
      allow create, update: if isStaff();
      allow delete: if isStaff();
    }
  }
}
